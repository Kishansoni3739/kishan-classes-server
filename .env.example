# Server configuration
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/kishan-classes?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=https://kishan-classes-rosy.vercel.app

# ImageKit Configuration (for media and avatar uploads)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=your_imagekit_url_endpoint

# Telegram Integration (optional, for alert broadcasts)
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_channel_or_group_id

# WhatsApp HTTP API (WAHA Integration) (optional)
WAHA_URL=your_waha_service_url
WAHA_USERNAME=your_waha_username
WAHA_PASSWORD=your_waha_password

# Email / SMTP Settings (optional, for mailers)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
